    {
      "parameters": {
        "jsCode": "// Extract winning patterns from high-performing ads\nconst highPerformers = $input.all();\n\n// Analyze common characteristics\nconst patterns = {\n  topCreatives: [],\n  commonThemes: [],\n  avgMetrics: {\n    ctr: 0,\n    cpc: 0,\n    conversions: 0,\n    roas: 0\n  },\n  insights: []\n};\n\n// Calculate average metrics\nlet totalCtr = 0, totalCpc = 0, totalConversions = 0, totalRoas = 0;\n\nhighPerformers.forEach(ad => {\n  totalCtr += ad.json.ctr || 0;\n  totalCpc += ad.json.cpc || 0;\n  totalConversions += ad.json.conversions || 0;\n  totalRoas += ad.json.roas || 0;\n  \n  // Collect top creatives\n  if (ad.json.creative) {\n    patterns.topCreatives.push({\n      id: ad.json.id,\n      name: ad.json.name,\n      creative: ad.json.creative,\n      score: ad.json.performanceScore\n    });\n  }\n});\n\nconst count = highPerformers.length || 1;\npatterns.avgMetrics.ctr = totalCtr / count;\npatterns.avgMetrics.cpc = totalCpc / count;\npatterns.avgMetrics.conversions = totalConversions / count;\npatterns.avgMetrics.roas = totalRoas / count;\n\n// Sort top creatives by score\npatterns.topCreatives.sort((a, b) => b.score - a.score);\n\n// Generate insights\npatterns.insights.push(`Analyzed ${count} high-performing ads`);\npatterns.insights.push(`Average CTR: ${patterns.avgMetrics.ctr.toFixed(2)}%`);\npatterns.insights.push(`Average ROAS: ${patterns.avgMetrics.roas.toFixed(2)}x`);\n\nreturn [{ json: patterns }];"
      },
      "id": "5a26cfdb-06e5-4794-8a8c-b3b05e97688b",
      "name": "Extract Winning Patterns",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1648,
        -128
      ]
    },
    {
      "parameters": {
        "jsCode": "// Build AI prompt for generating ad concepts\nconst patterns = $input.first().json;\n\nconst prompt = `You are an expert Meta Ads copywriter. Based on the following high-performing ad data, generate 5 new ad concepts.\n\nPerformance Summary:\n- Average CTR: ${patterns.avgMetrics.ctr.toFixed(2)}%\n- Average CPC: $${patterns.avgMetrics.cpc.toFixed(2)}\n- Average ROAS: ${patterns.avgMetrics.roas.toFixed(2)}x\n- Average Conversions: ${patterns.avgMetrics.conversions.toFixed(0)}\n\nTop Performing Ads:\n${patterns.topCreatives.slice(0, 5).map((ad, i) => `${i+1}. ${ad.name} (Score: ${ad.score})`).join('\\n')}\n\nKey Insights:\n${patterns.insights.join('\\n')}\n\nGenerate 5 new ad concepts in JSON format with the following structure:\n[\n  {\n    \"headline\": \"Compelling headline\",\n    \"primary_text\": \"Engaging primary text\",\n    \"cta\": \"Call to action\",\n    \"targeting_suggestion\": \"Recommended audience\"\n  }\n]\n\nReturn ONLY the JSON array, no additional text.`;\n\nreturn [{ json: { prompt } }];"
      },
      "id": "e813fb87-9145-4095-9fd0-511838da3e81",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
