      "id": "fff64b44-b518-4e95-863e-da67fccef644",
      "name": "Get Ad Insights",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        560,
        96
      ]
    },
    {
      "parameters": {
        "jsCode": "// Merge ad data with insights and calculate performance scores\nconst items = $input.all();\n\nconst scoredAds = items.map(item => {\n  const ad = item.json;\n  \n  // Calculate performance score based on key metrics\n  const ctr = parseFloat(ad.ctr) || 0;\n  const cpc = parseFloat(ad.cpc) || 0;\n  const conversions = parseFloat(ad.conversions) || 0;\n  const spend = parseFloat(ad.spend) || 0;\n  \n  // Scoring logic (customize based on your KPIs)\n  let score = 0;\n  \n  // CTR scoring (higher is better)\n  if (ctr > 2) score += 30;\n  else if (ctr > 1) score += 20;\n  else if (ctr > 0.5) score += 10;\n  \n  // CPC scoring (lower is better)\n  if (cpc < 0.5) score += 30;\n  else if (cpc < 1) score += 20;\n  else if (cpc < 2) score += 10;\n  \n  // Conversion scoring\n  if (conversions > 10) score += 40;\n  else if (conversions > 5) score += 25;\n  else if (conversions > 1) score += 15;\n  \n  // Determine performance tier\n  let performance_tier;\n  if (score >= 70) performance_tier = 'High';\n  else if (score >= 40) performance_tier = 'Medium';\n  else performance_tier = 'Low';\n  \n  return {\n    json: {\n      ...ad,\n      performance_score: score,\n      performance_tier: performance_tier\n    }\n  };\n});\n\nreturn scoredAds;"
      },
      "id": "73328182-4225-4a0b-8173-e7aba453f920",
      "name": "Merge and Score Ads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        784,
        96
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
